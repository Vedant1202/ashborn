{
  "name": "@ashborn-sec/bench",
  "version": "0.1.1",
  "description": "Offline replay harness and false-positive scorecard for Ashborn",
  "keywords": [
    "ai-security",
    "agent-security",
    "llm-security",
    "benchmark",
    "prompt-injection",
    "agentdojo"
  ],
  "license": "MIT",
  "author": "Vedant Nandoskar",
  "homepage": "https://github.com/Vedant1202/ashborn#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Vedant1202/ashborn.git",
    "directory": "packages/bench"
  },
  "bugs": {
    "url": "https://github.com/Vedant1202/ashborn/issues"
  },
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist",
    "fixtures"
  ],
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean --sourcemap",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@ashborn-sec/core": "workspace:*"
  }
}
