{
  "name": "ashborn-monorepo",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "A reproducible benchmark for agent-security signals, plus the tool-definition-drift detector",
  "license": "MIT",
  "packageManager": "pnpm@11.8.0",
  "engines": {
    "node": ">=22.13"
  },
  "scripts": {
    "build": "turbo run build",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "gen:fixtures": "uv run --with agentdojo scripts/gen-fixtures/generate.py",
    "release": "pnpm build && pnpm test && release-it && pnpm -r publish --no-git-checks",
    "release:dry": "release-it --dry-run --no-git.requireCleanWorkingDir",
    "release:version": "release-it --release-version --no-git.requireCleanWorkingDir",
    "release:changelog": "release-it --changelog --no-git.requireCleanWorkingDir",
    "release:github": "release-it --no-increment --no-git --github.release",
    "release:publish": "pnpm -r publish --no-git-checks"
  },
  "devDependencies": {
    "@eslint/js": "^9",
    "@release-it/bumper": "^7.0.6",
    "@release-it/conventional-changelog": "^11.0.1",
    "@types/node": "^24",
    "eslint": "^9",
    "prettier": "^3",
    "release-it": "^20.2.1",
    "tsup": "^8",
    "turbo": "^2",
    "typescript": "^5",
    "typescript-eslint": "^8",
    "vitest": "^3"
  }
}
